# Database Configuration
DATABASE_URL=your_postgresql_database_url_here

# Node.js 18.18+ recommended
# Node 22+ requires instrumentation.js for SSR safety

# Authentication Configuration (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# AI Configuration (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Redis Configuration (Optional - for distributed caching and rate limiting)
REDIS_URL=redis://your-redis-server:6379

# Rate Limiting Configuration
RATE_LIMIT_STORE=auto
RATE_LIMIT_REDIS_PREFIX=pathfinder:rate-limit

# AI Response Caching Configuration
# CACHE_STORE: "auto" (use Redis if available, else memory), "memory", or "redis"
CACHE_STORE=auto
CACHE_REDIS_PREFIX=pathfinder:cache
CACHE_TTL_MS=600000
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
